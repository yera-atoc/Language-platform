  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "'Я учу китайский' по-китайски:",
      "options": [
        "我会汉语。",
        "我喜欢汉语。",
        "我在学习汉语。",
        "我有汉语。"
      ],
      "correctAnswer": "我在学习汉语。",
      "explanation": "在 + глагол = сейчас делаю (настоящее продолженное). 我在学习汉语 = Я сейчас учу китайский."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "Как спросить 'Ты понимаешь?'",
      "options": [
        "你知道吗？",
        "你听吗？",
        "你懂吗？",
        "你明白吗？"
      ],
      "correctAnswer": "你懂吗？",
      "explanation": "懂 dǒng = понимать. Простой прямой вопрос. 我不懂 = Я не понимаю."
    },
    {
      "id": "ex_3",
