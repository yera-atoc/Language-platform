  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "'Я очень рад тебя видеть!' по-китайски:",
      "options": [
        "我很高兴认识你！",
        "我很高兴见到你！",
        "我很喜欢你！",
        "我很爱你！"
      ],
      "correctAnswer": "我很高兴见到你！",
      "explanation": "见到 = увидеть. 高兴 = радостный. 我很高兴见到你！= Я очень рад тебя видеть!"
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "Разница между 喜欢 и 爱:",
      "options": [
        "нет разницы",
        "喜欢 = нравится, 爱 = глубокая любовь",
        "喜欢 = любовь, 爱 = нравится",
        "оба = ненависть"
      ],
      "correctAnswer": "喜欢 = нравится, 爱 = глубокая любовь",
      "explanation": "喜欢 xǐhuan = нравиться (легче, повседневнее). 爱 ài = любить (глубже, серьёзнее). 我喜欢猫 = Мне нравятся кошки. 我爱妈妈 = Я люблю маму."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини эмоции",
      "pairs": [
        {
          "left": "高兴",
          "right": "радостный"
        },
        {
          "left": "难过",
          "right": "грустный"
        },
        {
          "left": "生气",
          "right": "злой"
        },
        {
          "left": "害怕",
          "right": "бояться"
        }
      ],
      "correctAnswer": "all",
      "explanation": "高兴=радостный, 难过=грустный, 生气=злой, 害怕=бояться."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "'Огромное спасибо!' по-китайски:",
      "options": [
        "谢谢！",
        "很谢谢！",
        "非常感谢！",
        "多谢！"
      ],
      "correctAnswer": "非常感谢！",
      "explanation": "非常 fēicháng = чрезвычайно/очень. 感谢 = благодарить. 非常感谢 = Огромное спасибо (более формально, чем 谢谢)."
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "«祝你生日___！» = «С днём рождения!»",
      "options": [
        "开心",
        "快乐",
        "高兴",
        "好"
      ],
      "correctAnswer": "快乐",
      "explanation": "生日快乐 = С днём рождения! 快乐 kuàilè = счастливый/радостный. Стандартное поздравление!"
    },
    {
      "id": "ex_6",
      "type": "multiple_choice",
      "question": "'Я беспокоюсь о тебе' по-китайски:",
