  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "'Какая у тебя работа?' по-китайски:",
      "options": [
        "你什么是？",
        "你做什么工作？",
        "你有什么？",
        "你是哪里人？"
      ],
      "correctAnswer": "你做什么工作？",
      "explanation": "做什么工作 = делать какую работу. 做 zuò = делать. 什么工作 = какую работу."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "'Я очень занят' по-китайски:",
      "options": [
        "我很累。",
        "我很忙。",
        "我很好。",
        "我很高兴。"
      ],
      "correctAnswer": "我很忙。",
      "explanation": "忙 máng = занятой. 我很忙 = Я очень занят. 累 = усталый — немного другое значение."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини профессии",
      "pairs": [
        {
          "left": "医生",
          "right": "врач"
        },
        {
          "left": "老师",
          "right": "учитель"
        },
        {
          "left": "工程师",
          "right": "инженер"
        },
        {
          "left": "同事",
          "right": "коллега"
        }
      ],
      "correctAnswer": "all",
      "explanation": "医生=врач, 老师=учитель, 工程师=инженер, 同事=коллега."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "'Я заканчиваю работу' по-китайски:",
      "options": [
        "我上班。",
        "我去班。",
        "我下班。",
        "我有班。"
      ],
      "correctAnswer": "我下班。",
      "explanation": "下班 xiàbān = заканчивать работу. 上班 = идти на работу. 上/下 = вверх/вниз (начало/конец)."
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "«我在大___工作» = «Я работаю в большой компании»",
      "options": [
        "学校",
        "医院",
        "公司",
        "商店"
      ],
      "correctAnswer": "公司",
      "explanation": "公司 gōngsī = компания. 在...工作 = работать в... Ключевая конструкция о месте работы."
    },
    {
      "id": "ex_6",
      "type": "multiple_choice",
      "question": "Что означает 周末好好休息？",
      "options": [
        "Работай в выходные",
        "Хорошо отдохни в выходные",
        "Встретимся в выходные",
        "Выходных нет"
      ],
      "correctAnswer": "Хорошо отдохни в выходные",
      "explanation": "周末 = выходные. 好好 = как следует/хорошо. 休息 = отдыхать. Популярное пожелание."
    },
    {
      "id": "ex_7",
      "type": "multiple_choice",
      "question": "'Зарплата высокая?' — как ответить 'да':",
      "options": [
        "有！",
        "是！",
        "高！",
        "好！"
      ],
      "correctAnswer": "高！",
      "explanation": "高 gāo = высокий. 工资高 = зарплата высокая. 工资低 = зарплата низкая."
    },
    {
      "id": "ex_8",
      "type": "fill_blank",
      "question": "«我___点下班» = «Я заканчиваю в шесть»",
      "options": [
        "五",
        "六",
        "七",
        "八"
      ],
      "correctAnswer": "六",
      "explanation": "六 = 6. 我六点下班 = Я заканчиваю работу в шесть часов."
    }
