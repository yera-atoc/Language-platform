  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "'Где туалет?' по-китайски:",
      "options": [
        "浴室在哪里？",
        "卫生间在哪里？",
        "厕所在哪里？",
        "洗手间在哪里？"
      ],
      "correctAnswer": "卫生间在哪里？",
      "explanation": "卫生间 wèishēngjiān — нейтральное слово для туалета. 厕所 = туалет (разговорное). Оба правильны."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "'Книга на столе' по-китайски:",
      "options": [
        "书在桌子下。",
        "桌子有书。",
        "书在桌子上。",
        "书和桌子。"
      ],
      "correctAnswer": "书在桌子上。",
      "explanation": "在桌子上 = на столе (上 = сверху/на). 书在桌子上 = Книга на столе."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини комнаты",
      "pairs": [
        {
          "left": "客厅",
          "right": "гостиная"
        },
        {
          "left": "卧室",
          "right": "спальня"
        },
        {
          "left": "厨房",
          "right": "кухня"
        },
        {
          "left": "卫生间",
          "right": "ванная"
        }
      ],
      "correctAnswer": "all",
      "explanation": "客厅=гостиная, 卧室=спальня, 厨房=кухня, 卫生间=ванная."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "'Я живу на третьем этаже' по-китайски:",
      "options": [
        "我在三楼。",
        "我住在三楼。",
        "我有三楼。",
        "我三楼住。"
      ],
      "correctAnswer": "我住在三楼。",
      "explanation": "住 zhù = жить/проживать. 在三楼 = на третьем этаже. 我住在...= Я живу на..."
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "«床很___» = «Кровать очень удобная»",
      "options": [
        "好看",
        "好吃",
        "舒服",
        "好听"
      ],
      "correctAnswer": "舒服",
      "explanation": "舒服 shūfu = удобный/комфортный. 床很舒服 = Кровать очень удобная. 不舒服 = некомфортно."
    },
    {
      "id": "ex_6",
      "type": "multiple_choice",
      "question": "'Хочу снять квартиру' по-китайски:",
      "options": [
        "我买房子。",
        "我卖房子。",
        "我想租房子。",
        "我有房子。"
      ],
      "correctAnswer": "我想租房子。",
      "explanation": "租 zū = арендовать. 想 = хотеть. 我想租房子 = Хочу снять квартиру."
    },
    {
      "id": "ex_7",
      "type": "multiple_choice",
      "question": "Что означает 打开窗户？",
      "options": [
        "Закрыть окно",
        "Открыть окно",
        "Купить окно",
        "Посмотреть в окно"
      ],
      "correctAnswer": "Открыть окно",
      "explanation": "打开 dǎkāi = открыть. 窗户 chuānghu = окно. 关上 guānshàng = закрыть."
    },
    {
      "id": "ex_8",
      "type": "fill_blank",
      "question": "«我住在___楼» = «Я живу на пятом этаже»",
      "options": [
        "三",
        "四",
        "五",
        "六"
      ],
      "correctAnswer": "五",
      "explanation": "五楼 = пятый этаж. 楼 = этаж. Запомни: в Китае часто нет 4-го этажа!"
    }
