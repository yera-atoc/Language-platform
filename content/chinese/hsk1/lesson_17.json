  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "Мерное слово для животных:",
      "options": [
        "个",
        "本",
        "只",
        "张"
      ],
      "correctAnswer": "只",
      "explanation": "只 zhī = мерное слово для животных (птицы, кошки, собаки). 条 tiáo = для рыб, змей. 头 tóu = для крупного скота."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "Панда по-китайски:",
      "options": [
        "老虎",
        "熊猫",
        "猫",
        "狗"
      ],
      "correctAnswer": "熊猫",
      "explanation": "熊猫 xióngmāo = панда. 熊 = медведь. 猫 = кошка. Буквально: «медведь-кошка». Символ Китая."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини животных",
      "pairs": [
        {
          "left": "猫",
          "right": "кошка"
        },
        {
          "left": "狗",
          "right": "собака"
        },
        {
          "left": "马",
          "right": "лошадь"
        },
        {
          "left": "老虎",
          "right": "тигр"
        }
      ],
      "correctAnswer": "all",
      "explanation": "猫=кошка, 狗=собака, 马=лошадь, 老虎=тигр."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "'У меня две кошки' по-китайски:",
      "options": [
        "我有两猫。",
        "我有两个猫。",
        "我有两只猫。",
        "我有二只猫。"
      ],
      "correctAnswer": "我有两只猫。",
      "explanation": "两只猫: 两 = два (при счёте), 只 = мерное слово для животных. НЕ 二个 — и число, и мерное слово важны!"
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "«熊猫是中国___» = «Панда — национальное сокровище Китая»",
