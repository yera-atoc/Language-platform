  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "«Hava nasıl bugün?» означает:",
      "options": [
        "Как ты сегодня?",
        "Какая сегодня погода?",
        "Где ты сегодня?",
        "Что сегодня?"
      ],
      "correctAnswer": "Какая сегодня погода?",
      "explanation": "hava = погода/воздух. nasıl = как. bugün = сегодня. Стандартный вопрос о погоде."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "«Bugün 35 derece» означает:",
      "options": [
        "Сегодня 35 минут",
        "Сегодня 35 градусов",
        "Сегодня 35 лир",
        "Сегодня 35 людей"
      ],
      "correctAnswer": "Сегодня 35 градусов",
      "explanation": "derece = градус. Bugün 35 derece! = Сегодня 35 градусов! Типичное турецкое лето."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини погоду с переводом",
      "pairs": [
        {
          "left": "güneşli",
          "right": "солнечно"
        },
        {
          "left": "yağmurlu",
          "right": "дождливо"
        },
        {
          "left": "karlı",
          "right": "снежно"
        },
        {
          "left": "bulutlu",
          "right": "облачно"
        }
      ],
      "correctAnswer": "all",
      "explanation": "güneşli=солнечно, yağmurlu=дождливо, karlı=снежно, bulutlu=облачно."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "«Yazın çok sıcak» означает:",
      "options": [
        "Летом очень холодно",
        "Зимой очень жарко",
        "Летом очень жарко",
        "Весной очень тепло"
      ],
      "correctAnswer": "Летом очень жарко",
      "explanation": "yaz = лето, -ın = суффикс времени (летом). sıcak = жарко. yazın = летом."
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "«Kışın çok ___» = «Зимой очень холодно»",
