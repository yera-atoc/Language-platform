    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "«Otobüse biniyorum» означает:",
      "options": [
        "Я жду автобус",
        "Я выхожу из автобуса",
        "Я сажусь в автобус",
        "Я ищу автобус"
      ],
      "correctAnswer": "Я сажусь в автобус",
      "explanation": "binmek = садиться в транспорт. otobüs + -e = в автобус (суффикс направления)."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "«Transfer yapmam lazım» означает:",
      "options": [
        "Мне нужно купить билет",
        "Мне нужно сделать пересадку",
        "Мне нужно подождать",
        "Мне нужно выйти"
      ],
      "correctAnswer": "Мне нужно сделать пересадку",
      "explanation": "transfer = пересадка. yapmak = делать. lazım = нужно."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини транспорт с переводом",
