        { "left": "Hayır", "right": "Нет" },
        { "left": "Merhaba", "right": "Привет" },
        { "left": "Rica ederim", "right": "Пожалуйста" }
      ],
      "correctAnswer": "all"
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "Ты уходишь из дома. Что скажешь остающимся?",
      "options": ["Hoşça kal", "Güle güle", "Merhaba", "Günaydın"],
      "correctAnswer": "Güle güle",
      "explanation": "Güle güle говорит тот, кто уходит. Hoşça kal говорит тот, кто остаётся."
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "Допиши фразу: «İyi _______» (Добрый день)",
      "options": ["günler", "geceler", "sabahlar", "akşamlar"],
      "correctAnswer": "günler",
      "explanation": "İyi günler = Добрый день. İyi akşamlar = Добрый вечер."
