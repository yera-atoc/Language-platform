      "id": "ex_1",
      "type": "multiple_choice",
      "question": "Как по-турецки будет «Доброе утро»?",
      "options": ["Merhaba", "Günaydın", "İyi akşamlar", "Hoşça kal"],
      "correctAnswer": "Günaydın",
      "explanation": "Günaydın используется утром. Дословно: «хороший рассвет»."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "Что означает «Teşekkür ederim»?",
      "options": ["Привет", "Пока", "Спасибо", "Пожалуйста"],
      "correctAnswer": "Спасибо",
      "explanation": "Teşekkür ederim — официальная форма «спасибо». Неформально: Sağ ol."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини турецкие слова с переводом",
