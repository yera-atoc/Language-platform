  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "Сейчас 3:30. Как сказать по-турецки?",
      "options": [
        "Üç buçuk",
        "Üç çeyrek",
        "Üçte bir",
        "Saat üç"
      ],
      "correctAnswer": "Üç buçuk",
      "explanation": "Üç buçuk = 3:30. buçuk = половина. saat üç buçuk = половина четвёртого."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "«Gece» означает:",
      "options": [
        "утро",
        "день",
        "вечер",
        "ночь"
      ],
      "correctAnswer": "ночь",
      "explanation": "gece = ночь. sabah = утро. öğlen = полдень. akşam = вечер."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини время суток с переводом",
      "pairs": [
        {
          "left": "sabah",
          "right": "утро"
        },
        {
          "left": "öğlen",
          "right": "полдень"
        },
        {
          "left": "akşam",
          "right": "вечер"
        },
        {
          "left": "gece",
          "right": "ночь"
        }
      ],
      "correctAnswer": "all",
      "explanation": "sabah=утро, öğlen=полдень, akşam=вечер, gece=ночь."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "«Saat kaç?» означает:",
      "options": [
        "Который час?",
        "Сколько стоит?",
        "Сколько минут?",
        "Как дела?"
      ],
      "correctAnswer": "Который час?",
      "explanation": "Saat kaç? = Который час? saat = час/часы, kaç = сколько."
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "«Çok ___» = «Очень поздно»",
      "options": [
        "erken",
        "geç",
        "şimdi",
        "yarın"
      ],
      "correctAnswer": "geç",
      "explanation": "geç = поздно. erken = рано. Geç kalma! = Не опаздывай!"
    },
    {
      "id": "ex_6",
      "type": "multiple_choice",
      "question": "Как сказать «Я встаю рано»?",
      "options": [
        "Geç kalkıyorum.",
        "Erken kalkıyorum.",
        "Şimdi kalkıyorum.",
        "Yarın kalkıyorum."
      ],
      "correctAnswer": "Erken kalkıyorum.",
      "explanation": "erken = рано. kalkıyorum = я встаю (от kalkmak = вставать)."
    },
    {
      "id": "ex_7",
      "type": "multiple_choice",
      "question": "В котором часу обед? «Öğle yemeği saat ___de»",
      "options": [
        "birde",
        "bende",
        "birinde",
        "bir"
      ],
      "correctAnswer": "birde",
      "explanation": "bir + -de = в час. birde = в час (дня). Суффикс -de = в/на."
    },
    {
      "id": "ex_8",
      "type": "fill_blank",
      "question": "«Ne ___ geliyorsun?» = «Когда ты приходишь?»",
      "options": [
        "kadar",
        "zaman",
        "biraz",
        "çok"
      ],
      "correctAnswer": "zaman",
      "explanation": "Ne zaman = когда. Saat kaç = в котором часу. Разные вопросы!"
    }
