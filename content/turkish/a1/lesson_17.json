  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "«Üç odalı daire arıyorum» означает:",
      "options": [
        "Я снимаю трёхкомнатную квартиру",
        "Ищу трёхкомнатную квартиру",
        "У меня трёхкомнатная квартира",
        "Покупаю трёхкомнатную квартиру"
      ],
      "correctAnswer": "Ищу трёхкомнатную квартиру",
      "explanation": "arıyorum = ищу (от aramak). üç odalı = трёхкомнатный. daire = квартира."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "«Kira ne kadar?» означает:",
      "options": [
        "Какой размер?",
        "Сколько комнат?",
        "Сколько аренда?",
        "Где квартира?"
      ],
      "correctAnswer": "Сколько аренда?",
      "explanation": "kira = аренда/съём. ne kadar = сколько. Kira ne kadar? = Сколько аренда?"
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини комнаты с переводом",
      "pairs": [
        {
          "left": "mutfak",
          "right": "кухня"
        },
        {
          "left": "banyo",
          "right": "ванная"
        },
        {
          "left": "salon",
          "right": "гостиная"
        },
        {
          "left": "yatak odası",
          "right": "спальня"
        }
      ],
      "correctAnswer": "all",
      "explanation": "mutfak=кухня, banyo=ванная, salon=гостиная, yatak odası=спальня."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "«Masada kitap var» означает:",
      "options": [
        "Книга большая",
        "На столе есть книга",
