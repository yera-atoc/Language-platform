  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "«Sağa dönün» означает:",
      "options": [
        "Идите прямо",
        "Поверните налево",
        "Поверните направо",
        "Остановитесь"
      ],
      "correctAnswer": "Поверните направо",
      "explanation": "sağ = правый. dönmek = поворачивать. Sağa dönün = Поверните направо."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "Как спросить «Где аптека?»",
      "options": [
        "Eczane kaçta?",
        "Eczane nerede?",
        "Eczane ne kadar?",
        "Eczane var mı?"
      ],
      "correctAnswer": "Eczane nerede?",
      "explanation": "nerede = где. eczane = аптека. Nerede? — вопрос о местонахождении."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини места с переводом",
      "pairs": [
        {
          "left": "hastane",
          "right": "больница"
        },
        {
          "left": "okul",
          "right": "школа"
        },
        {
          "left": "restoran",
          "right": "ресторан"
        },
        {
          "left": "eczane",
          "right": "аптека"
        }
      ],
      "correctAnswer": "all",
      "explanation": "hastane=больница, okul=школа, restoran=ресторан, eczane=аптека."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "«Düz gidin» означает:",
      "options": [
        "Поверните",
