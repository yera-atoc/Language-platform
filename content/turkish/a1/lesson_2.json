      "id": "ex_3",
      "type": "multiple_choice",
      "question": "Что означает местоимение «O»?",
      "options": ["Я", "Ты", "Он / Она / Оно", "Мы"],
      "correctAnswer": "Он / Она / Оно",
      "explanation": "В турецком «O» используется для всех: он, она, оно. Рода нет!"
    },
    {
      "id": "ex_4",
      "type": "match_pairs",
      "question": "Соедини местоимения с переводом",
