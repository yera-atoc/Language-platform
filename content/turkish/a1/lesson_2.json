      "type": "multiple_choice",
      "question": "Как по-турецки «Как тебя зовут?»",
      "options": ["Nerelisin?", "Adın ne?", "Memnun oldum", "Kaç yaşındasın?"],
      "correctAnswer": "Adın ne?",
      "explanation": "Adın ne? = Как тебя зовут? Дословно: «Твоё имя что?»"
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "Что означает «Memnun oldum»?",
      "options": ["Пока!", "Спасибо", "Приятно познакомиться", "Не за что"],
      "correctAnswer": "Приятно познакомиться",
      "explanation": "Memnun oldum = Приятно познакомиться. Используется при первом знакомстве."
    },
