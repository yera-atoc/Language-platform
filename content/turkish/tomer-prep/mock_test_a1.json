  "exercises": [
    { "id":"t1","type":"multiple_choice","question":"Что означает «Merhaba»?","options":["Пока","Привет","Спасибо","Извините"],"correctAnswer":"Привет","explanation":"Merhaba = Привет/Здравствуйте — самое базовое приветствие." },
    { "id":"t2","type":"multiple_choice","question":"Как по-турецки «Доброе утро»?","options":["İyi akşamlar","İyi geceler","Günaydın","Hoşça kal"],"correctAnswer":"Günaydın","explanation":"Günaydın = Доброе утро. İyi akşamlar = Добрый вечер." },
    { "id":"t3","type":"multiple_choice","question":"Что означает «beş»?","options":["3","4","5","6"],"correctAnswer":"5","explanation":"beş = 5. Числа: bir(1), iki(2), üç(3), dört(4), beş(5)." },
    { "id":"t4","type":"multiple_choice","question":"Как по-турецки «красный»?","options":["mavi","yeşil","sarı","kırmızı"],"correctAnswer":"kırmızı","explanation":"kırmızı = красный — цвет турецкого флага." },
    { "id":"t5","type":"multiple_choice","question":"Что означает «anne»?","options":["папа","бабушка","сестра","мама"],"correctAnswer":"мама","explanation":"anne = мама. baba = папа." },
    { "id":"t6","type":"multiple_choice","question":"Как по-турецки «воскресенье»?","options":["Pazartesi","Cuma","Cumartesi","Pazar"],"correctAnswer":"Pazar","explanation":"Pazar = воскресенье. Cumartesi = суббота." },
    { "id":"t7","type":"multiple_choice","question":"Что означает «ekmek»?","options":["вода","хлеб","молоко","мясо"],"correctAnswer":"хлеб","explanation":"ekmek = хлеб — основа турецкого стола." },
    { "id":"t8","type":"multiple_choice","question":"Как по-турецки «50»?","options":["kırk","elli","altmış","yetmiş"],"correctAnswer":"elli","explanation":"elli = 50. kırk = 40, altmış = 60." },
    { "id":"t9","type":"multiple_choice","question":"Что означает «sabah»?","options":["ночь","вечер","утро","полдень"],"correctAnswer":"утро","explanation":"sabah = утро. gece = ночь. akşam = вечер." },
    { "id":"t10","type":"multiple_choice","question":"Как спросить «Где?»","options":["Ne zaman?","Nasıl?","Nerede?","Ne kadar?"],"correctAnswer":"Nerede?","explanation":"Nerede? = Где? ne zaman? = когда? nasıl? = как?" },
    { "id":"t11","type":"multiple_choice","question":"Что означает «köpek»?","options":["кошка","собака","птица","рыба"],"correctAnswer":"собака","explanation":"köpek = собака. kedi = кошка." },
    { "id":"t12","type":"multiple_choice","question":"Как по-турецки «нос»?","options":["göz","kulak","burun","ağız"],"correctAnswer":"burun","explanation":"burun = нос. göz = глаз. kulak = ухо." },
    { "id":"t13","type":"multiple_choice","question":"Что означает «yağmur»?","options":["снег","ветер","дождь","солнце"],"correctAnswer":"дождь","explanation":"yağmur = дождь. kar = снег. güneş = солнце." },
    { "id":"t14","type":"multiple_choice","question":"Как спросить «Сколько стоит?»","options":["Nerede?","Nasılsın?","Ne kadar?","Nerelisin?"],"correctAnswer":"Ne kadar?","explanation":"Ne kadar? = Сколько стоит? Очень нужная фраза!" },
    { "id":"t15","type":"multiple_choice","question":"Что означает «uçak»?","options":["поезд","корабль","самолёт","автобус"],"correctAnswer":"самолёт","explanation":"uçak = самолёт. uçmak = летать." },
    { "id":"t16","type":"multiple_choice","question":"Как по-турецки «учитель»?","options":["doktor","avukat","öğretmen","mühendis"],"correctAnswer":"öğretmen","explanation":"öğretmen = учитель. öğrenmek = учиться." },
    { "id":"t17","type":"multiple_choice","question":"Что означает «mutfak»?","options":["спальня","кухня","гостиная","ванная"],"correctAnswer":"кухня","explanation":"mutfak = кухня. yatak odası = спальня." },
    { "id":"t18","type":"multiple_choice","question":"Как по-турецки «платье»?","options":["gömlek","etek","ceket","elbise"],"correctAnswer":"elbise","explanation":"elbise = платье. etek = юбка. gömlek = рубашка." },
    { "id":"t19","type":"multiple_choice","question":"Что означает «mutlu»?","options":["грустный","злой","счастливый","усталый"],"correctAnswer":"счастливый","explanation":"mutlu = счастливый. üzgün = грустный." },
    { "id":"t20","type":"multiple_choice","question":"Как ответить «Я хорошо» на «Nasılsın?»","options":["Kötüyüm","İyiyim","Yorgunum","Hastayım"],"correctAnswer":"İyiyim","explanation":"İyiyim = Я хорошо. Kötüyüm = Я плохо." },
    { "id":"t21","type":"fill_blank","question":"«_______» означает «спасибо» по-турецки:","options":["Merhaba","Rica ederim","Teşekkür ederim","Hoşça kal"],"correctAnswer":"Teşekkür ederim","explanation":"Teşekkür ederim = Спасибо (официально). Rica ederim = Пожалуйста." },
    { "id":"t22","type":"fill_blank","question":"Цифра 7 по-турецки:","options":["altı","yedi","sekiz","dokuz"],"correctAnswer":"yedi","explanation":"yedi = 7. altı = 6, sekiz = 8, dokuz = 9." },
    { "id":"t23","type":"fill_blank","question":"«_______ kaç?» = «Сколько времени?»","options":["Gün","Hava","Saat","Para"],"correctAnswer":"Saat","explanation":"Saat kaç? = Сколько времени? saat = час/время." },
    { "id":"t24","type":"multiple_choice","question":"Как по-турецки «больница»?","options":["okul","market","hastane","park"],"correctAnswer":"hastane","explanation":"hastane = больница. hasta = больной + -hane = место." },
    { "id":"t25","type":"multiple_choice","question":"Что означает «beyaz»?","options":["чёрный","красный","белый","синий"],"correctAnswer":"белый","explanation":"beyaz = белый. siyah = чёрный. Цвета флага Турции: kırmızı ve beyaz." }
  ]
