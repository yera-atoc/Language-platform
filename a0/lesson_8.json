  "dialogue": {
    "title": "Диалог",
    "context": "Практика.",
    "lines": [
      {
        "speaker": "Зарина",
        "tr": "Merhaba! Adım Zarina. Ben Kazakistanlıyım.",
        "ru": "Привет! Меня зовут Зарина. Я из Казахстана.",
        "note": "Полное представление с именем и страной."
      },
      {
        "speaker": "Мехмет",
        "tr": "Merhaba Zarina! Ben Mehmet. İstanbul'dan geliyorum.",
        "ru": "Привет Зарина! Я Мехмет. Я из Стамбула.",
        "note": "İstanbul'dan = из Стамбула. -dan = суффикс 'из'."
      },
      {
        "speaker": "Зарина",
        "tr": "Kaç yaşındasın, Mehmet?",
        "ru": "Сколько тебе лет, Мехмет?",
        "note": "Прямой вопрос о возрасте — в Турции это норма."
      },
      {
        "speaker": "Мехмет",
        "tr": "Yirmi beş yaşındayım. Sen?",
        "ru": "Мне 25 лет. А ты?",
        "note": "yirmi beş = 25."
      },
      {
        "speaker": "Зарина",
        "tr": "Ben yirmi iki yaşındayım. Türkçe öğreniyorum.",
        "ru": "Мне 22. Учу турецкий.",
        "note": "öğreniyorum = учу (сейчас)."
      },
      {
        "speaker": "Мехмет",
        "tr": "Harika! Türkçen çok iyi!",
        "ru": "Отлично! Твой турецкий очень хорош!",
        "note": "Türkçe+n = твой турецкий (-n суффикс владения)."
      }
    ]
  },
  "cultural_note": {
    "title": "Турецкое гостеприимство",
    "text": "Турки известны своим гостеприимством (misafirpeverlik). Гость (misafir) — священный человек. Поговорка: 'Misafir on kisilik nasibini getirir' = Гость приносит удачу на десятерых. В первые минуты знакомства обязательно предложат чай. Отказаться — невежливо. Интерес к стране гостя и вопросы о семье — норма, не любопытство."
  },
