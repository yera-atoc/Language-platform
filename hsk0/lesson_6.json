  "dialogue": {
    "title": "Практика урока 6",
    "context": "Тренируем произношение.",
    "lines": [
      {
        "speaker": "Ань",
        "tr": "早上好，王老师！",
        "ru": "Доброе утро, учитель Ван!",
        "note": "王老师 = учитель Ван (фамилия + учитель)"
