  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "«Çok mutluyum» означает:",
      "options": [
        "Я очень грустный",
        "Я очень злой",
        "Я очень счастливый",
        "Я очень устал"
      ],
      "correctAnswer": "Я очень счастливый",
      "explanation": "mutlu = счастливый. çok = очень. -yum = я есть."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "«Neden üzgünsün?» означает:",
      "options": [
        "Как ты?",
        "Почему ты грустишь?",
        "Ты в порядке?",
        "Что случилось?"
      ],
      "correctAnswer": "Почему ты грустишь?",
      "explanation": "neden = почему. üzgün = грустный. -sun = ты есть. Neden üzgünsün? = Почему ты грустный?"
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини эмоции с переводом",
      "pairs": [
        {
          "left": "mutlu",
          "right": "счастливый"
        },
        {
          "left": "üzgün",
          "right": "грустный"
        },
        {
          "left": "kızgın",
          "right": "злой"
        },
        {
          "left": "yorgun",
          "right": "усталый"
        }
      ],
      "correctAnswer": "all",
      "explanation": "mutlu=счастливый, üzgün=грустный, kızgın=злой, yorgun=усталый."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "«Seni seviyorum» означает:",
      "options": [
        "Я скучаю по тебе",
        "Я тебя люблю",
        "Я тебя вижу",
        "Я тебя слышу"
      ],
      "correctAnswer": "Я тебя люблю",
      "explanation": "seviyorum = люблю (от sevmek). seni = тебя (винительный от sen)."
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "«Çok ___yım» = «Я очень взволнован»",
      "options": [
        "heyecanlı",
        "heyecanl",
        "heyecanlıy",
        "heyecanlar"
      ],
      "correctAnswer": "heyecanlıy",
      "explanation": "heyecanlıyım = я взволнован. heyecanlı + -yım. y добавляется перед гласным суффиксом."
    },
    {
      "id": "ex_6",
      "type": "multiple_choice",
      "question": "«Karanlıktan korkuyorum» означает:",
      "options": [
        "Я люблю темноту",
        "Я боюсь темноты",
        "Я не вижу в темноте",
        "Я хожу в темноте"
