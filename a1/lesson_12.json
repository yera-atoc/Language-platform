  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "«Başım ağrıyor» означает:",
      "options": [
        "У меня болит живот",
        "У меня болит голова",
        "У меня болит нога",
        "У меня болит рука"
      ],
      "correctAnswer": "У меня болит голова",
      "explanation": "baş = голова, -ım = мой, ağrıyor = болит. Başım ağrıyor = У меня болит голова."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "Как сказать «У меня болит зуб»?",
      "options": [
        "Dişim ağrıyor.",
        "Gözüm ağrıyor.",
        "Kulağım ağrıyor.",
        "Ayağım ağrıyor."
      ],
      "correctAnswer": "Dişim ağrıyor.",
      "explanation": "diş = зуб, -im = мой, ağrıyor = болит. Запомни эту фразу для стоматолога!"
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини части тела с переводом",
      "pairs": [
        {
          "left": "baş",
          "right": "голова"
        },
        {
          "left": "göz",
          "right": "глаз"
        },
        {
          "left": "el",
          "right": "рука"
        },
        {
          "left": "ayak",
          "right": "нога"
        }
      ],
      "correctAnswer": "all",
      "explanation": "baş=голова, göz=глаз, el=рука, ayak=нога."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "«Doktora gitmem lazım» означает:",
      "options": [
        "Я был у врача",
        "Мне нужно идти к врачу",
        "Врач пришёл",
        "Я врач"
      ],
      "correctAnswer": "Мне нужно идти к врачу",
      "explanation": "lazım = нужно/необходимо. gitmem = моё хождение. Doktora gitmem lazım = Мне нужно к врачу."
    },
    {
      "id": "ex_5",
