  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "В магазине: «Kredi kartı geçerli mi?» означает:",
      "options": [
        "Есть скидка?",
        "Кредитная карта принимается?",
        "Где касса?",
        "Могу примерить?"
      ],
      "correctAnswer": "Кредитная карта принимается?",
      "explanation": "kredi kartı = кредитная карта. geçerli = принимается/действительна."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "«Kaç beden?» спрашивают в магазине, когда хотят узнать:",
      "options": [
        "цену",
        "цвет",
        "размер",
        "наличие"
      ],
      "correctAnswer": "размер",
      "explanation": "beden = размер (одежды). numara = размер (обуви). Kaç beden? = Какой размер?"
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини слова с переводом",
      "pairs": [
        {
          "left": "kasa",
          "right": "касса"
        },
        {
          "left": "indirim",
          "right": "скидка"
        },
        {
          "left": "iade",
          "right": "возврат"
        },
        {
          "left": "fatura",
          "right": "чек"
        }
      ],
      "correctAnswer": "all",
      "explanation": "kasa=касса, indirim=скидка, iade=возврат, fatura=чек."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "«Deneyebilir miyim?» означает:",
      "options": [
        "Могу купить?",
        "Могу вернуть?",
        "Могу примерить?",
        "Могу посмотреть?"
      ],
      "correctAnswer": "Могу примерить?",
      "explanation": "denemek = примерять. -ebilir miyim? = могу ли я? Deneyebilir miyim? = Могу я примерить?"
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "«Maalesef ___» = «К сожалению, нет»",
      "options": [
        "var",
        "tamam",
        "evet",
        "yok"
      ],
      "correctAnswer": "yok",
      "explanation": "yok = нет (нет в наличии). Maalesef yok = К сожалению, нет. Maalesef = к сожалению."
    },
    {
      "id": "ex_6",
      "type": "multiple_choice",
      "question": "Как спросить «Есть другой цвет?»",
      "options": [
        "Başka fiyat var mı?",
        "Başka beden var mı?",
        "Başka rengi var mı?",
        "Başka mağaza var mı?"
      ],
      "correctAnswer": "Başka rengi var mı?",
      "explanation": "başka = другой/ещё. renk = цвет. var mı? = есть ли? Başka rengi var mı? = Есть другой цвет?"
    },
    {
      "id": "ex_7",
      "type": "multiple_choice",
      "question": "«Nakit mi kart mı?» — что спрашивает кассир?",
      "options": [
        "Большой или маленький?",
        "Дорого или дёшево?",
        "Наличными или картой?",
        "Один или два?"
      ],
      "correctAnswer": "Наличными или картой?",
      "explanation": "nakit = наличные. kart = карта. -mi ... -mi? = ... или ...?"
    },
    {
      "id": "ex_8",
      "type": "fill_blank",
      "question": "«İade ___ miyim?» = «Могу я вернуть?»",
      "options": [
        "edebilir",
        "ediyor",
        "eden",
        "etti"
      ],
      "correctAnswer": "edebilir",
      "explanation": "iade edebilir miyim? = могу ли я вернуть? -ebilir = мочь/возможность."
    }
