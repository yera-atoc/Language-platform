  "dialogue": {
    "title": "В ресторане — делаем заказ",
    "context": "Туристка заказывает обед в турецком ресторане.",
    "lines": [
      {
        "speaker": "Официант",
        "tr": "Hoş geldiniz! Menü buyrun.",
        "ru": "Добро пожаловать! Вот меню.",
        "note": "Hoş geldiniz = добро пожаловать. buyrun = пожалуйста (вот)."
      },
      {
        "speaker": "Зара",
        "tr": "Teşekkürler. Ne tavsiye edersiniz?",
        "ru": "Спасибо. Что вы рекомендуете?",
        "note": "tavsiye etmek = рекомендовать. -siniz = вы (формально)."
      },
      {
        "speaker": "Официант",
        "tr": "Izgara tavuk çok güzel bugün.",
        "ru": "Сегодня куриный гриль очень хорошо.",
        "note": "ızgara = гриль. bugün = сегодня."
      },
      {
        "speaker": "Зара",
        "tr": "Tamam, ızgara tavuk istiyorum. Ve salata.",
        "ru": "Хорошо, я хочу куриный гриль. И салат.",
        "note": "tamam = хорошо/ладно. salata = салат."
      },
      {
        "speaker": "Официант",
        "tr": "İçecek olarak ne istersiniz?",
        "ru": "Что будете пить?",
        "note": "içecek = напиток. olarak = в качестве."
      },
      {
        "speaker": "Зара",
        "tr": "Ayran lütfen. Ayran nedir?",
        "ru": "Айран, пожалуйста. Что такое айран?",
        "note": "nedir = что это такое? nе+dir(суффикс «есть»)."
      },
      {
        "speaker": "Официант",
        "tr": "Ayran bir Türk içeceği — yoğurt ve su.",
        "ru": "Айран — турецкий напиток — йогурт и вода.",
        "note": "çok sağlıklı ve lezzetli! = очень полезный и вкусный!"
      }
    ]
