  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "Кошка по-турецки:",
      "options": [
        "köpek",
        "kuş",
        "kedi",
        "at"
      ],
      "correctAnswer": "kedi",
      "explanation": "kedi = кошка. köpek = собака. kuş = птица. at = лошадь."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "«Sevimli» означает:",
      "options": [
        "большой",
        "быстрый",
        "умный",
        "милый/симпатичный"
      ],
      "correctAnswer": "милый/симпатичный",
      "explanation": "sevimli = милый, симпатичный. sev- от sevmek = любить. -imli суффикс качества."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини животных с переводом",
      "pairs": [
        {
          "left": "kedi",
          "right": "кошка"
        },
        {
          "left": "aslan",
          "right": "лев"
        },
        {
          "left": "fil",
          "right": "слон"
        },
        {
          "left": "tavşan",
          "right": "кролик"
        }
      ],
      "correctAnswer": "all",
      "explanation": "kedi=кошка, aslan=лев, fil=слон, tavşan=кролик."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "«Filler çok akıllı» означает:",
      "options": [
        "Слоны очень большие",
        "Слоны очень умные",
        "Слоны очень быстрые",
        "Слоны очень красивые"
      ],
      "correctAnswer": "Слоны очень умные",
      "explanation": "filler = слоны (fil + -ler = мн.ч.), akıllı = умный. çok = очень."
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "«Köpeğim çok ___» = «Моя собака очень милая»",
      "options": [
        "büyük",
        "hızlı",
        "sevimli",
        "güçlü"
      ],
      "correctAnswer": "sevimli",
      "explanation": "sevimli = милый. Köpeğim çok sevimli = Моя собака очень милая."
    },
    {
      "id": "ex_6",
      "type": "multiple_choice",
      "question": "«Yılandan korkuyorum» означает:",
      "options": [
        "Я люблю змей",
        "Я вижу змею",
        "Я боюсь змей",
        "Я ищу змею"
      ],
      "correctAnswer": "Я боюсь змей",
      "explanation": "korkuyorum = боюсь (от korkmak = бояться). yılandan = от/змеи (-dan = от)."
    },
    {
      "id": "ex_7",
      "type": "multiple_choice",
      "question": "Как сказать «У меня есть собака»?",
      "options": [
        "Köpek yok.",
        "Köpeğim var.",
        "Ben köpek.",
        "Köpek seviyorum."
      ],
      "correctAnswer": "Köpeğim var.",
      "explanation": "Köpek + -im (мой) + var (есть) = Köpeğim var = У меня есть собака."
    },
    {
      "id": "ex_8",
