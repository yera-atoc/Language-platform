  "exercises": [
    {
      "id": "ex_1",
      "type": "multiple_choice",
      "question": "«Ben öğretmenim» означает:",
      "options": [
        "Я студент",
        "Я учитель",
        "Я учусь",
        "Мой учитель"
      ],
      "correctAnswer": "Я учитель",
      "explanation": "öğretmen = учитель. -im = я есть. Ben öğretmenim = Я учитель."
    },
    {
      "id": "ex_2",
      "type": "multiple_choice",
      "question": "«Nerede çalışıyorsunuz?» означает:",
      "options": [
        "Кем вы работаете?",
        "Где вы работаете?",
        "Когда вы работаете?",
        "Как вы работаете?"
      ],
      "correctAnswer": "Где вы работаете?",
      "explanation": "nerede = где. çalışıyorsunuz = вы работаете. Вопрос о месте работы."
    },
    {
      "id": "ex_3",
      "type": "match_pairs",
      "question": "Соедини профессии с переводом",
      "pairs": [
        {
          "left": "doktor",
          "right": "врач"
        },
        {
          "left": "avukat",
          "right": "адвокат"
        },
        {
          "left": "hemşire",
          "right": "медсестра"
        },
        {
          "left": "pilot",
          "right": "пилот"
        }
      ],
      "correctAnswer": "all",
      "explanation": "doktor=врач, avukat=адвокат, hemşire=медсестра, pilot=пилот."
    },
    {
      "id": "ex_4",
      "type": "multiple_choice",
      "question": "«Emekli» означает:",
      "options": [
        "безработный",
        "студент",
        "пенсионер",
        "рабочий"
      ],
      "correctAnswer": "пенсионер",
      "explanation": "emekli = пенсионер. işsiz = безработный. öğrenci = студент."
    },
    {
      "id": "ex_5",
      "type": "fill_blank",
      "question": "«___ olmak istiyorum» = «Я хочу стать поваром»",
