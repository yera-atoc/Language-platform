    },
    {
      "id": "ex_6",
      "type": "multiple_choice",
      "question": "«Ne iş yapıyorsunuz?» — что спрашивают?",
      "options": [
        "Где вы живёте?",
        "Чем вы занимаетесь?",
        "Как вас зовут?",
        "Откуда вы?"
